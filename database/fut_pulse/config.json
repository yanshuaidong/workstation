  "_history_help": {
    "history_date_step_x": "【关键精度参数】相邻两个日期之间的像素间距。校准时框选区域的宽度 = x2-x1。若 hover 落点偏移（比如总是差半格），在此直接修改这个数字，正数=向右，负数=向左。示例：23 表示每天间隔23像素。",
    "history_latest_date_x": "【起始点X】最新一天的 hover X 坐标，即校准框选区域的右边界 x2。若最新日期 hover 有偏差，在这里微调（+/- 几像素）。",
    "history_date_bar_y": "【hover Y坐标】鼠标在日期轴上 hover 的垂直位置，校准框选区域的上下中线。若 tooltip 不出现或出现在错误位置，上下微调这个值。",
    "history_date_region": "校准时框选的原始区域 [x1,y1,x2,y2]，仅记录用，程序实际用上面三个计算值。",
    "history_count": "每个合约收集多少天历史数据，默认30。",
    "history_hover_delay": "hover 后等待多少秒再截图（等 tooltip 弹出），默认0.8秒。若截图内容为空或 tooltip 未出现，适当加大此值。",
    "调整建议": [
      "1. 先用截图工具（选项4）测试截图区域是否对准",
      "2. history_latest_date_x 对准最新日期的竖线中心（屏幕坐标，可用画图工具查看像素位置）",
      "3. history_date_step_x 若偏小则 hover 点过密，偏大则跨越了多天，需精确测量相邻两日期线的像素距离",
      "4. history_date_bar_y 调整到日期文字所在行的垂直中心",
      "5. history_hover_delay 若 tooltip 弹出慢，改为 1.0 或 1.2"
    ]
  }
